# Unreal Engine 5 .gitignore

# Compiled source / Binaries
Binaries/
Intermediate/
Plugins/*/Binaries/
Plugins/*/Intermediate/

# Cache files
DerivedDataCache/

# Editor-generated config & session data
Saved/

# Build artifacts
Build/

# Don't ignore icon files in Build
!Build/**/*.ico

# Visual Studio files
.vs/
*.sln
*.suo
*.opensdf
*.sdf
*.VC.db
*.VC.opendb

# JetBrains IDEs
.idea/
*.iml

# macOS
.DS_Store

# Windows
Thumbs.db

# Log files
*.log
